# PostgreSQL connection (read-only user recommended in production)
DATABASE_URL="postgresql://user:password@localhost:5432/letravail?schema=public"

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://letravail.ma"

# ISR revalidation interval in seconds (default: 3600 = 1 hour)
REVALIDATE_SECONDS=3600

# Optional: secret for on-demand revalidation webhook after scrape
# REVALIDATE_SECRET="your-secret-here"

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification meta content value
NEXT_PUBLIC_GSC_VERIFICATION=
