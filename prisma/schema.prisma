generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id             String    @id @default(cuid())
  source         String
  sourceJobId    String
  hash           String    @unique
  slug           String    @unique
  title          String
  company        String
  city           String
  country        String    @default("Morocco")
  description    String    @db.Text
  requirements   String?   @db.Text
  salary         String?
  contractType   String?
  remote         Boolean   @default(false)
  applicationUrl String
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  companyId  String?
  locationId String?
  companyRef Company? @relation(fields: [companyId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])
  tags       JobTag[]

  @@unique([source, sourceJobId])
  @@index([slug])
  @@index([title])
  @@index([company])
  @@index([city])
  @@index([publishedAt])
  @@index([source])
  @@index([hash])
  @@map("jobs")
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  websiteUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@index([slug])
  @@index([name])
  @@map("companies")
}

model Location {
  id        String   @id @default(cuid())
  city      String
  country   String   @default("Morocco")
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@unique([city, country])
  @@index([city])
  @@index([slug])
  @@map("locations")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  jobs      JobTag[]

  @@index([slug])
  @@index([name])
  @@map("tags")
}

model JobTag {
  jobId String
  tagId String
  job   Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tag   Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
  @@map("job_tags")
}

model Subscriber {
  id         String   @id @default(cuid())
  email      String   @unique
  citySlug   String?
  sectorSlug String?
  source     String   @default("website")
  createdAt  DateTime @default(now())

  @@index([sectorSlug])
  @@index([citySlug])
  @@map("subscribers")
}

model JobTitleTaxonomy {
  id         String   @id @default(cuid())
  slug       String   @unique
  label      String
  parentSlug String?
  sectorSlug String?
  keywords   String[] @default([])
  createdAt  DateTime @default(now())

  @@index([sectorSlug])
  @@map("job_title_taxonomy")
}

/// First-class profession entity — powers profession pages, salary links, knowledge graph
model Profession {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  aliases      String[] @default([])
  sectorSlug   String?
  skills       String[] @default([])
  salarySlug   String?
  relatedSlugs String[] @default([])
  keywords     String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sectorSlug])
  @@index([salarySlug])
  @@map("professions")
}

model Skill {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("skills")
}

model SalaryObservation {
  id           String   @id @default(cuid())
  jobId        String
  titleNorm    String
  citySlug     String?
  sectorSlug   String?
  salaryMin    Int?
  salaryMax    Int?
  currency     String   @default("MAD")
  contractType String?
  observedAt   DateTime @default(now())
  source       String   @default("scraped")

  @@index([titleNorm, citySlug])
  @@index([sectorSlug, observedAt])
  @@index([jobId])
  @@map("salary_observations")
}

model MarketSnapshot {
  id           String   @id @default(cuid())
  weekStart    DateTime
  citySlug     String?
  sectorSlug   String?
  jobCount     Int
  medianSalary Int?
  topSkills    Json     @default("[]")
  topCompanies Json     @default("[]")

  @@unique([weekStart, citySlug, sectorSlug])
  @@index([weekStart])
  @@map("market_snapshots")
}

model ScrapeLog {
  id           String    @id @default(cuid())
  source       String
  category     String
  status       String
  startedAt    DateTime
  endedAt      DateTime?
  durationMs   Int?
  jobsFound    Int       @default(0)
  jobsInserted Int       @default(0)
  jobsUpdated  Int       @default(0)
  duplicates   Int       @default(0)
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([category])
  @@index([startedAt])
  @@index([status])
  @@map("scrape_logs")
}

model GscPageMetric {
  id          String   @id @default(cuid())
  pagePath    String
  pageType    String
  query       String   @default("")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  periodStart DateTime
  periodEnd   DateTime
  ingestedAt  DateTime @default(now())

  @@unique([pagePath, query, periodStart, periodEnd])
  @@index([pagePath])
  @@index([periodEnd])
  @@map("gsc_page_metrics")
}

model GscQueryMetric {
  id          String   @id @default(cuid())
  query       String
  pagePath    String   @default("")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  periodStart DateTime
  periodEnd   DateTime
  ingestedAt  DateTime @default(now())

  @@unique([query, pagePath, periodStart, periodEnd])
  @@index([query])
  @@map("gsc_query_metrics")
}

model SeoActionLog {
  id        String   @id @default(cuid())
  action    String
  status    String
  message   String   @db.Text
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@map("seo_action_logs")
}

model SerpIntelligenceRecord {
  id                 String    @id @default(cuid())
  provider           String
  keyword            String
  pagePath           String?
  ourPosition        Float?
  competitorDomain   String?
  competitorPosition Float?
  searchVolume       Int?
  capturedAt         DateTime  @default(now())
  periodStart        DateTime?
  periodEnd          DateTime?
  raw                Json      @default("{}")

  @@index([keyword])
  @@index([provider])
  @@index([capturedAt])
  @@map("serp_intelligence_records")
}
